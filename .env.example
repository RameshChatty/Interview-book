# PostgreSQL connection string (Supabase, Neon, or any Postgres provider)
DATABASE_URL="postgresql://user:password@host:5432/stackscribe"

# Better Auth
# Generate a strong secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
# Public base URL of the app
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional OAuth providers (leave blank to disable)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
